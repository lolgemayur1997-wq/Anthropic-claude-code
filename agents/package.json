{
  "name": "ai-workflow-agents",
  "version": "1.0.0",
  "type": "module",
  "description": "AI workflow pipeline using Google Gemini (free tier)",
  "scripts": {
    "pipeline": "bun run orchestrator.ts",
    "review": "bun run orchestrator.ts --stage review",
    "test-gen": "bun run orchestrator.ts --stage test",
    "docs": "bun run orchestrator.ts --stage docs",
    "verify": "bun run orchestrator.ts --stage verify",
    "intraday": "bun run intraday-research.ts",
    "intraday:mock": "bun run intraday-research.ts --adapter mock --dry-run"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/bun": "latest"
  }
}
